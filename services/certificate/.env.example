# Server Configuration
PORT=3009
SERVICE_NAME=certificate-service
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:27017/eduelderly-certificate

# Cloudinary (PDF storage — optional post-MVP)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Public app URL for verify links
APP_URL=http://localhost:8080

# Internal Service Key (shared across all services)
INTERNAL_SERVICE_KEY=dev_internal_key_987654321
