# Server Configuration
PORT=3007
SERVICE_NAME=notification-service
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:27017/eduelderly-notification

# Brevo transactional email
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=EduElderly

# Internal Service Key (shared across all services)
INTERNAL_SERVICE_KEY=dev_internal_key_987654321
