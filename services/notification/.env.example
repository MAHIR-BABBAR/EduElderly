# Server Configuration
PORT=3007
SERVICE_NAME=notification-service
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:27017/eduelderly-notification

# Email (SendGrid or SMTP via Nodemailer)
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
FROM_EMAIL=noreply@eduelderly.com
FROM_NAME=EduElderly

# SMTP fallback (if not using SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Inter-service URLs
ENROLLMENT_SERVICE_URL=http://enrollment:3004

# Internal Service Key (shared across all services)
INTERNAL_SERVICE_KEY=dev_internal_key_987654321
