# Server Configuration
PORT=3006
SERVICE_NAME=payment-service
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:27017/eduelderly-payment

# Razorpay (primary payment gateway)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Stripe (fallback payment gateway)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Inter-service URLs
ENROLLMENT_SERVICE_URL=http://enrollment:3004

# Internal Service Key (shared across all services)
INTERNAL_SERVICE_KEY=dev_internal_key_987654321
