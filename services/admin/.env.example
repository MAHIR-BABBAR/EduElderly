# Server Configuration
PORT=3008
SERVICE_NAME=admin-service
NODE_ENV=development

# MongoDB (recommend read replica in production)
MONGO_URI=mongodb://mongo:27017/eduelderly-admin

# Inter-service URLs (all services for cross-service aggregation)
AUTH_SERVICE_URL=http://auth:3001
USER_SERVICE_URL=http://user:3002
COURSE_SERVICE_URL=http://course:3003
ENROLLMENT_SERVICE_URL=http://enrollment:3004
QUIZ_SERVICE_URL=http://quiz:3005
PAYMENT_SERVICE_URL=http://payment:3006
NOTIFICATION_SERVICE_URL=http://notification:3007
CERTIFICATE_SERVICE_URL=http://certificate:3009

# Internal Service Key (shared across all services)
INTERNAL_SERVICE_KEY=dev_internal_key_987654321
