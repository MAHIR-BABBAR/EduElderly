# Server Configuration
PORT=8080
SERVICE_NAME=gateway
NODE_ENV=development

# Service URLs
# Docker Compose: http://auth:3001, http://course:3003, ...
# Local host dev: use localhost URLs for each service
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
COURSE_SERVICE_URL=http://localhost:3003
ENROLLMENT_SERVICE_URL=http://localhost:3004
QUIZ_SERVICE_URL=http://quiz:3005
PAYMENT_SERVICE_URL=http://payment:3006
NOTIFICATION_SERVICE_URL=http://notification:3007
ADMIN_SERVICE_URL=http://admin:3008
CERTIFICATE_SERVICE_URL=http://certificate:3009

# Security / JWT (must match services/auth JWT_ACCESS_SECRET)
JWT_ACCESS_SECRET=dev_access_secret_key_change_in_production
INTERNAL_SERVICE_KEY=dev_internal_key_987654321

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_LOGIN_MAX_REQUESTS=10

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
