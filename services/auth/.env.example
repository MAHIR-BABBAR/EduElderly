# Server Configuration
PORT=3001
SERVICE_NAME=auth-service
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:27017/eduelderly-auth

# JWT Secrets
JWT_ACCESS_SECRET=dev_access_secret_key_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_key_change_in_production

# Bcrypt
BCRYPT_ROUNDS=12

# Internal Service Key (shared across all services)
INTERNAL_SERVICE_KEY=dev_internal_key_987654321

# Notification Service (for OTP emails)
NOTIFICATION_SERVICE_URL=http://notification:3007
