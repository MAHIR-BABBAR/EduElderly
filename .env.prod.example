# Production secrets — copy to .env.prod at repo root for docker-compose.prod.yml
# Generate strong random values; never commit .env.prod

MONGO_ROOT_USER=eduelderly_admin
MONGO_ROOT_PASSWORD=change_me_strong_mongo_password
REDIS_PASSWORD=change_me_strong_redis_password
GATEWAY_PORT=8080

# Each service .env file must also define (same values across services):
# INTERNAL_SERVICE_KEY=<strong-random-key>
# JWT_ACCESS_SECRET=<strong-random-key>  (gateway + auth)
# JWT_REFRESH_SECRET=<strong-random-key>  (auth only)
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
