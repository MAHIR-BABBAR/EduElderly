{
  "name": "eduelderly-root",
  "version": "1.0.0",
  "description": "Initial release - EduElderly Platform",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "client"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "dev:gateway": "cd services/gateway && npm run dev",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint 'services/**/*.js' 'packages/**/*.js'",
    "format": "prettier --write '**/*.{js,jsx,json}'"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
